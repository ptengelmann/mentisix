{
  "name": "@mentisix/brand",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Mentisix design tokens, mark, icons, and pattern primitives.",
  "type": "module",
  "sideEffects": ["./src/styles/*.css", "./dist/styles/*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "default": "./dist/tokens.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.theme.d.ts",
      "import": "./dist/tailwind.theme.js",
      "default": "./dist/tailwind.theme.js"
    },
    "./mark": {
      "types": "./dist/mark.d.ts",
      "import": "./dist/mark.js",
      "default": "./dist/mark.js"
    },
    "./patterns": {
      "types": "./dist/patterns.d.ts",
      "import": "./dist/patterns.js",
      "default": "./dist/patterns.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js",
      "default": "./dist/icons/index.js"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/fonts.css": "./src/styles/fonts.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -R src/styles dist/styles",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@mentisix/config-typescript": "workspace:*",
    "@types/react": "^19.0.1",
    "typescript": "5.7.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0"
  }
}

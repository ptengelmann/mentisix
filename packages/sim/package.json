{
  "name": "@mentisix/sim",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Grid-world cognition engine — pure TS, no I/O.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "biome check src tests",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@mentisix/config-typescript": "workspace:*",
    "typescript": "5.7.2",
    "@types/node": "22.10.2",
    "vitest": "2.1.8"
  }
}
